  "keyFeatures": [
    "Consumer groups with automatic load balancing — no partitions required",
    "Dead-Letter Queues (DLQ) for unprocessable poison-pill messages",
    "Raft consensus for leader election and log replication",
    "Persistent Write-Ahead Log (WAL) with segment-based storage",
    "Follower-based reads for horizontal read scalability",
    "Automatic producer and consumer failover with bootstrap servers",
    "Prometheus metrics endpoint via Micrometer",
    "Multi-language client SDKs: Java, Python, TypeScript",
    "Interactive CLI for producing and consuming messages",
    "Single-node and cluster deployment modes"
  ],
